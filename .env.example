# Firebase — récupère ces valeurs dans la console Firebase :
# https://console.firebase.google.com → Ton projet → Paramètres (engrenage) → Général → "Mes applications"
# Pour databaseURL : Realtime Database → voir l’URL en haut (ex. https://xxx.firebaseio.com ou https://xxx-default-rtdb.europe-west1.firebasedatabase.app)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# Optionnel : monitoring erreurs
# VITE_SENTRY_DSN=

# Optionnel : en dev, utiliser les émulateurs Firebase au lieu de la prod
# VITE_USE_FIREBASE_EMULATOR=true
