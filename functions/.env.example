# Copier en .env et remplir. Ne pas committer .env
RESEND_API_KEY=re_xxxxx
# Plusieurs emails possibles, séparés par des virgules
ADMIN_EMAIL=email1@gmail.com,email2@gmail.com
SITE_URL=https://maison-mayssa.fr
# Instance Realtime Database (console Firebase → Realtime Database → nom en haut de l’URL)
RTDB_INSTANCE=maison-mayssa-default-rtdb
# Expéditeur (optionnel). Défaut : Maison Mayssa <onboarding@resend.dev>
# Pour utiliser ton domaine : vérifie-le dans Resend puis mets ex. : FROM_EMAIL=Maison Mayssa <noreply@maison-mayssa.fr>
# FROM_EMAIL=Maison Mayssa <noreply@maison-mayssa.fr>

# Stripe — clé SECRÈTE (sk_test_… puis sk_live_…). Ne JAMAIS committer.
STRIPE_SECRET_KEY=sk_test_xxxxx
# Secret du webhook Stripe (whsec_…) — obtenu après création du webhook dans le dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
